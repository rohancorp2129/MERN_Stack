{
    "manifest_version": 3,
    "name": "Digital Clock & Quick Links",
    "version": "1.0",
    "description": "A beautiful digital clock with quick access links",
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": ["storage","tabs","activeTab"],
    "chrome_url_overrides": {
        "newtab": "index.html"
    }
}